{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git",
    "opencode-cmux"
  ],
  "default_agent": "architect",
  "agent": {
    "architect": {
      "color": "#71b084"
    },
    "api-designer": {
      "color": "#e9edc9"
    },
    "backend-developer": {
      "color": "#71a5de"
    },
    "code-reviewer": {
      "color": "#adb5bd"
    },
    "debugger": {
      "color": "#f4a261"
    },
    "devops-engineer": {
      "color": "#bbd0ff"
    },
    "frontend-developer": {
      "color": "#fbc4ab"
    },
    "planner": {
      "color": "#606c38"
    },
    "qa-expert": {
      "color": "#cdb4db"
    },
    "rust-engineer": {
      "color": "#f77f00"
    },
    "typescript-pro": {
      "color": "#3178C6"
    },
    "ui-designer": {
      "color": "#ffafcc"
    },
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    },
    "general": {
      "disable": true,
      "color": "#f1faee"
    }
  },
  "mcp": {
    "chrome-devtools": {
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "type": "local"
    },
    "context7": {
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "type": "local"
    },
    "engram": {
      "command": ["engram", "mcp", "--tools=agent"],
      "enabled": true,
      "type": "local"
    },
    "firecrawl-mcp": {
      "command": ["npx", "-y", "firecrawl-mcp"],
      "environment": {
        "FIRECRAWL_API_KEY": "$API_KEY"
      },
      "type": "local"
    }
  },
  "permission": {
    "bash": "allow",
    "edit": "allow",
    "external_directory": "deny",
    "webfetch": "allow",
    "read": "allow",
    "codesearch": "allow",
    "glob": "allow",
    "grep": "allow",
    "skill": "allow",
    "websearch": "allow",
    "list": "allow",
    "lsp": "allow",
    "task": "allow",
    "question": "allow",
    "todowrite": "allow",
    "doom_loop": "allow"
  }
}
