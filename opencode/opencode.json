{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"],
  "default_agent": "architect",
  "agent": {
    "general": {
      "color": "#f1faee"
    },
    "architect": {
      "color": "#71b084"
    },
    "frontend-architect": {
      "color": "#fbc4ab"
    },
    "api-design-architect": {
      "color": "#e9edc9"
    },
    "typescript-quality-guardian": {
      "color": "#3178C6"
    },
    "backend-reliability-engineer": {
      "color": "#71a5de"
    },
    "database-performance-optimizer": {
      "color": "#dedbd2"
    },
    "devops-engineer": {
      "color": "#bbd0ff"
    },
    "security-architect": {
      "color": "#E06C75"
    },
    "risk-advisor": {
      "color": "#ffb5a7"
    },
    "session-closer": {
      "color": "#606c38"
    },
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    }
  },
  "mcp": {
    "chrome-devtools": {
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "type": "local"
    },
    "context7": {
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "type": "local"
    },
    "engram": {
      "command": ["engram", "mcp", "--tools=agent"],
      "enabled": true,
      "type": "local"
    },
    "firecrawl-mcp": {
      "command": ["npx", "-y", "firecrawl-mcp"],
      "environment": {
        "FIRECRAWL_API_KEY": "$API_KEY"
      },
      "type": "local"
    }
  },
  "permission": {
    "bash": "allow",
    "edit": "allow",
    "external_directory": "deny",
    "webfetch": "allow",
    "read": "allow",
    "codesearch": "allow",
    "glob": "allow",
    "grep": "allow",
    "skill": "allow",
    "websearch": "allow",
    "list": "allow",
    "lsp": "allow",
    "task": "allow",
    "question": "allow",
    "todowrite": "allow",
    "doom_loop": "allow"
  },
  "provider": {
    "openrouter": {
      "models": {
        "DS::v3.2": {
          "id": "deepseek/deepseek-v3.2",
          "options": {
            "include_reasoning": true,
            "provider": {
              "order": [
                "deepinfra",
                "atlascloud",
                "novita",
                "siliconflow",
                "chutes",
                "parasail"
              ],
              "allow_fallbacks": false
            }
          }
        }
      }
    }
  }
}
